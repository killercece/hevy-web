# Configuration Flask Hevy-Web
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1

# Clé secrète - CHANGER en production (openssl rand -hex 32)
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32

# Base de données - laisser vide pour chemin absolu auto ./data/hevy.db
# DATABASE_URL=sqlite:////absolute/path/to/hevy.db

# Système d'unités par défaut (metric ou imperial)
DEFAULT_UNIT_SYSTEM=metric

# Utilisateur admin créé au premier lancement
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin
